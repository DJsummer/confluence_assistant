# ── Confluence ──────────────────────────────────────────────
CONFLUENCE_BASE=https://confluence.XXXX.com
CONFLUENCE_USER=your_user
CONFLUENCE_TOKEN=your_token

# ── Embedding（本地 bge-m3，sentence-transformers 推理）──────
EMBEDDING_MODEL=BAAI/bge-m3        # 或本地路径 /models/bge-m3
EMBEDDING_DEVICE=cpu               # ⬅ 无显卡填 cpu，有显卡填 cuda
EMBEDDING_BATCH_SIZE=32
VECTOR_DIM=1024

# ── LLM（vLLM 本地部署）─────────────────────────────────────
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
LLM_BASE_URL=http://vllm:8000/v1   # docker-compose 内网；裸机改为 http://localhost:8001/v1
VLLM_API_KEY=token-local

# ── 模型缓存目录（容器内路径，通过 volume 挂载）─────────────
HF_CACHE_DIR=/models

# ── Milvus ──────────────────────────────────────────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=confluence_docs
VECTOR_DIM=1536

# ── PostgreSQL（元数据）─────────────────────────────────────
POSTGRES_DSN=postgresql://rag:rag@localhost:5432/ragdb

# ── Redis（缓存 + Celery broker）───────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── 切分 ────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Confluence 抓取目标 ─────────────────────────────────────
ROOT_TITLE=FA_EM_SERVICE
SPACE_KEY=UICA
