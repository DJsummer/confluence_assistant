# ── Confluence ───────────────────────────────────────────────────────────────
CONFLUENCE_BASE=https://confluence.XXXX.com
CONFLUENCE_USER=your_user
CONFLUENCE_TOKEN=your_token

# ── Jira ─────────────────────────────────────────────────────────────────────
JIRA_BASE=https://jira.XXXX.com
JIRA_USER=your_user
JIRA_TOKEN=your_token      # 通常与 Confluence token 相同

# ── Pronto ───────────────────────────────────────────────────────────────────
PRONTO_BASE=https://pronto.XXXX.com

# ── Embedding（本地 bge-m3，sentence-transformers 推理）──────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu               # ⬅ 无显卡填 cpu，有显卡填 cuda
EMBEDDING_BATCH_SIZE=32
VECTOR_DIM=1024

# ── LLM（默认指向 Ollama，可换阿里百炼）──────────────────────────────────────
LLM_MODEL=qwen2.5:7b
LLM_BASE_URL=http://host.docker.internal:11434/v1
VLLM_API_KEY=ollama
# 阿里百炼 API 示例：
# LLM_MODEL=qwen-plus
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# VLLM_API_KEY=sk-your_key

# ── 模型缓存目录（容器内路径，通过 volume 挂载）──────────────────────────────
HF_CACHE_DIR=/models

# ── Milvus ───────────────────────────────────────────────────────────────────
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=confluence_docs

# ── PostgreSQL（元数据）──────────────────────────────────────────────────────
POSTGRES_DSN=postgresql://rag:rag@postgres:5432/ragdb

# ── Redis（缓存 + Celery broker）─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── 切分 ─────────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Confluence 抓取目标 ───────────────────────────────────────────────────────
ROOT_TITLE=Your_Space_Home
SPACE_KEY=SPACE
